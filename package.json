{
  "name": "hamster-orbit-sky-sprint",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Hamster Orbit: Sky Sprint - a 3D arcade roll-and-race YouTube Playable",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "npm run typecheck && npm run lint && npm run test && npm run build",
    "analyze": "vite build && node scripts/analyze.mjs"
  },
  "dependencies": {
    "three": "^0.180.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/three": "^0.180.0",
    "eslint": "^9.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
